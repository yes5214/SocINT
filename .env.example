# Discord Security Bot - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: Bot Authentication
# ============================================================================
DISCORD_TOKEN=your_discord_bot_token_here
VT_API_KEY=your_virustotal_api_key_here

# ============================================================================
# OPTIONAL: Detection Thresholds (based on testing results)
# ============================================================================

# URL Detection Threshold (0-100)
# Testing Results:
#   - Threshold 40: 60% accuracy (missed 8/10 phishing URLs)
#   - Threshold 25: 90% accuracy ✅ (caught 9/10 phishing URLs)
# Recommendation: 25 (default)
URL_DETECTION_THRESHOLD=25

# File Detection Threshold (0-100)
# Testing Results:
#   - Threshold 40: Missed most malware
#   - Threshold 25: 65% accuracy (missed 4/10 malware)
#   - Threshold 15: Recommended for better recall
# Recommendation: 15 (default)
# Note: Lower threshold catches more malware but may increase false positives
FILE_DETECTION_THRESHOLD=15

# ============================================================================
# TESTING NOTES
# ============================================================================
# Based on testing with 40 real samples (20 URLs + 20 files):
#
# URL Scanner Performance (Threshold 25):
#   - Accuracy:  90.00% ✅
#   - Precision: 90.00% ✅
#   - Recall:    90.00% ✅
#   - F1 Score:  90.00% ✅
#   - Status: PRODUCTION READY
#
# File Scanner Performance (Threshold 25):
#   - Accuracy:  65.00% ⚠️
#   - Precision: 66.67% ⚠️
#   - Recall:    60.00% (missed 4/10 malware) 🚨
#   - F1 Score:  63.16% ⚠️
#   - Status: NEEDS IMPROVEMENT
#
# Recommendation: Use different thresholds for URLs vs Files
# See FINAL_TEST_RESULTS.md for detailed analysis
# ============================================================================
